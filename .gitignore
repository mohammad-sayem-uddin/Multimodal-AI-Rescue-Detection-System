# ============================================================
# Multimodal AI Rescue Detection System — .gitignore
# ============================================================

# --------------------
# NODE / REACT / VITE
# --------------------
node_modules/
dist/
build/
.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache

# --------------------
# PYTHON
# --------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
*.egg
eggs/
*.whl
sdist/
MANIFEST

# --------------------
# VIRTUAL ENVIRONMENTS
# --------------------
venv/
.venv/
env/
ENV/

# --------------------
# ENVIRONMENT & SECRETS
# --------------------
.env
.env.local
.env.*.local
!.env.example

# --------------------
# OS FILES
# --------------------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
*.swp
*.swo
*~

# --------------------
# IDE / EDITOR FILES
# --------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# --------------------
# TEMPORARY FILES
# --------------------
*.tmp
*.temp
*.bak
*.log

# --------------------
# ML / AI GENERATED ARTIFACTS
# --------------------
runs/
wandb/
mlruns/
outputs/
predictions/
cache/

# --------------------
# MODEL WEIGHTS (large / reproducible — download as needed)
# --------------------
*.pt
*.pth
*.ckpt
*.onnx
*.h5
*.keras
*.tflite

# --------------------
# DATASETS (large / local only)
# --------------------
datasets/
data/raw/
data/processed/

# --------------------
# UNRELATED PROJECTS
# --------------------
gitlab-vscode-extension-main/GEMINI.md
**/GEMINI.md
gitlab-vscode-extension-main/
